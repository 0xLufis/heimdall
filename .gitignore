# ==========================================
# Infrastructure / Docker / PostgreSQL
# ==========================================
# NEVER commit database data or logs
infra/database/data/
infra/database/logs/

infra/database/secrets/*.txt
infra/database/certs/*.key
infra/database/certs/*.crt

# (Optional) If you want to commit dummy secrets for other devs, 
# you can use an exclusion like this, but generally, ignore them all:
# !infra/database/secrets/example_secret.txt

